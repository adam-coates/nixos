# Zathura config
include ~/.config/zathura/theme.conf

# Keybindings
map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map r reload
map R rotate
map K zoom in
map J zoom out
map i recolor
map p print

# Toggle plain white/black (default) with 'i' already handles recolor
# Use 'i' to toggle between themed and plain white background

# General settings
set selection-clipboard clipboard
set render-loading      true
set adjust-open         best-fit
set pages-per-row       1
set scroll-step         50
